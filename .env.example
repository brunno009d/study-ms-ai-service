# Google Gemini AI Config (solo para parsing de PDFs/imágenes)
GOOGLE_API_KEY=tu_api_key_de_google_aqui
VISION_MODEL_NAME=gemini-2.5-flash

# OpenRouter Config (modelos gratis para chat y consejero)
OPENROUTER_API_KEY=tu_open_router_api_key_aqui
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_FALLBACK_MODEL=google/gemma-4-31b-it:free

# Server Config
PORT=3006

# URL del microservicio de notas y demás microservicios (comunicación inter-servicios)
NOTES_SERVICE_URL=http://localhost:3005
USER_SERVICE_URL=http://localhost:3001
CURRICULUM_SERVICE_URL=http://localhost:3002
GRADES_SERVICE_URL=http://localhost:3003
CALENDAR_SERVICE_URL=http://localhost:3004

# Supabase Auth Config (Para validación de JWT y acceso a la base de datos de chat)
SUPABASE_URL=https://tu_proyecto.supabase.co
SUPABASE_SERVICE_ROLE=tu_service_role_key_aqui
